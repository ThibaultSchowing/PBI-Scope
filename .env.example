# NCBI credentials — required for host genome downloads
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose reads .env automatically and passes these variables into
# the pipeline container. Never commit your .env file to version control.

# Your email address — required by NCBI Terms of Service
NCBI_EMAIL=your.email@example.com

# NCBI API key — optional but strongly recommended (10x faster downloads)
# Get a free key at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# ── Non-root container execution ─────────────────────────────────────────────
# Set these so containers write files as your user (not root).
# Run the one-liner below once after copying this file:
#
#   echo "UID=$(id -u)" >> .env
#   echo "GID=$(id -g)" >> .env
#
# Default (1000:1000) is fine on most single-user Linux desktops.
# On macOS Docker Desktop file ownership is handled transparently —
# setting these values is still safe and has no negative effect.
UID=1000
GID=1000

# Optional override for private-data mount path inside containers.
# Default in docker-compose.yml: /private-data
PBI_PRIVATE_DATA_DIR=/private-data

# Optional output directory for notebook exports in the analysis container.
# Default in docker-compose.yml: /results
PBI_RESULTS_DIR=/results

# ── Agentic chat (agent + ollama services) ───────────────────────────────────
# Ollama model to pull and serve (requires ~6 GB VRAM for Q4 quantisation).
# Pull after first start: docker exec pbi-ollama ollama pull llama3.1:8b
OLLAMA_MODEL=llama3.1:8b

# Security limits for the agent tools
# Maximum log file content returned per read (in KB)
AGENT_MAX_LOG_SIZE_KB=512
# Maximum rows returned per SQL query
AGENT_SQL_ROW_LIMIT=500

# Optional bearer-token to protect the /chat/stream endpoint.
# Leave empty to disable authentication (suitable for SSH-tunnelled access only).
AGENT_API_KEY=

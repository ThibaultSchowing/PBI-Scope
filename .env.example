# NCBI credentials — required for host genome downloads
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose reads .env automatically and passes these variables into
# the pipeline container. Never commit your .env file to version control.

# Your email address — required by NCBI Terms of Service
NCBI_EMAIL=your.email@example.com

# NCBI API key — optional but strongly recommended (10x faster downloads)
# Get a free key at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
